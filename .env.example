# Director AI can run without a model key by using mock generation.
DIRECTOR_AI_PROVIDER=mock

# Optional: set DIRECTOR_AI_PROVIDER=gemini and provide a server-side key.
# Never expose this as NEXT_PUBLIC_*.
DIRECTOR_AI_API_KEY=
DIRECTOR_AI_GEMINI_MODEL=gemini-2.5-flash

# Optional server-side debug logs for AI route/provider selection.
DIRECTOR_AI_DEBUG=false
